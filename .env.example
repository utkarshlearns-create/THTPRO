# Core Django settings
DEBUG=False
SECRET_KEY=replace-with-long-random-secret
ALLOWED_HOSTS=thtpro-backend.onrender.com,localhost,127.0.0.1
DATABASE_URL=postgres://user:password@host:5432/dbname

# Frontend origins (comma-separated)
CORS_ALLOWED_ORIGINS=https://thtpro.vercel.app,http://localhost:3000
CSRF_TRUSTED_ORIGINS=https://thtpro.vercel.app,http://localhost:3000

# Google OAuth (Google Cloud Console > OAuth Client)
GOOGLE_CLIENT_ID=1234567890-abcdefg.apps.googleusercontent.com

# Cloudinary (Cloudinary dashboard API keys)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=replace-with-cloudinary-secret

# Razorpay webhook security (Razorpay Dashboard > Webhooks)
RAZORPAY_WEBHOOK_SECRET=replace-with-razorpay-webhook-secret

# MSG91 OTP delivery (MSG91 dashboard)
MSG91_AUTH_KEY=replace-with-msg91-authkey
MSG91_TEMPLATE_ID=replace-with-msg91-template-id

# Optional operational settings
WELCOME_BONUS_CREDITS=500
SUPERUSER_PHONE=9876543210
SUPERUSER_PASSWORD=replace-with-strong-password
SUPERUSER_USERNAME=superadmin
